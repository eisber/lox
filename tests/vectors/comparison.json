{
  "category": "C: Comparison",
  "blocks": {
    "Comparator": {
      "inputs": {"I1": "analog", "I2": "analog"},
      "outputs": {"GT": "digital", "EQ": "digital", "LT": "digital"},
      "tests": [
        {"desc": "5>3", "set": {"I1": 5.0, "I2": 3.0}, "expect": {"GT": 1, "EQ": 0, "LT": 0}},
        {"desc": "3<5", "set": {"I1": 3.0, "I2": 5.0}, "expect": {"GT": 0, "EQ": 0, "LT": 1}},
        {"desc": "4=4", "set": {"I1": 4.0, "I2": 4.0}, "expect": {"GT": 0, "EQ": 1, "LT": 0}},
        {"desc": "0=0", "set": {"I1": 0.0, "I2": 0.0}, "expect": {"GT": 0, "EQ": 1, "LT": 0}},
        {"desc": "-1<1", "set": {"I1": -1.0, "I2": 1.0}, "expect": {"GT": 0, "EQ": 0, "LT": 1}}
      ]
    },
    "ThresholdSwitch": {
      "inputs": {"I": "analog"},
      "outputs": {"Q": "digital"},
      "tests": [
        {"desc": "below threshold", "set": {"I": 0.0}, "expect": {"Q": 0}},
        {"desc": "above threshold", "set": {"I": 100.0}, "expect": {"Q": 1}},
        {"desc": "at threshold", "set": {"I": 50.0}, "expect": {"Q": 1}}
      ]
    },
    "MinMax": {
      "inputs": {"I1": "analog", "I2": "analog"},
      "outputs": {"Min": "analog", "Max": "analog"},
      "tests": [
        {"desc": "3,7", "set": {"I1": 3.0, "I2": 7.0}, "expect": {"Min": 3.0, "Max": 7.0}},
        {"desc": "10,2", "set": {"I1": 10.0, "I2": 2.0}, "expect": {"Min": 2.0, "Max": 10.0}},
        {"desc": "5,5", "set": {"I1": 5.0, "I2": 5.0}, "expect": {"Min": 5.0, "Max": 5.0}},
        {"desc": "-3,3", "set": {"I1": -3.0, "I2": 3.0}, "expect": {"Min": -3.0, "Max": 3.0}}
      ]
    },
    "AnalogLimiter": {
      "inputs": {"I": "analog"},
      "outputs": {"AQ": "analog"},
      "tests": [
        {"desc": "within range", "set": {"I": 50.0}, "expect": {"AQ": 50.0}},
        {"desc": "at zero", "set": {"I": 0.0}, "expect": {"AQ": 0.0}},
        {"desc": "above max (clamped to 100)", "set": {"I": 200.0}, "expect": {"AQ": 100.0}},
        {"desc": "below min (clamped to 0)", "set": {"I": -50.0}, "expect": {"AQ": 0.0}}
      ]
    },
    "AnalogWatchdog": {
      "inputs": {"I": "analog"},
      "outputs": {"Q": "digital"},
      "tests": [
        {"desc": "in range", "set": {"I": 50.0}, "expect": {"Q": 1}},
        {"desc": "out of range low", "set": {"I": -100.0}, "expect": {"Q": 0}},
        {"desc": "out of range high", "set": {"I": 200.0}, "expect": {"Q": 0}}
      ]
    }
  },
  "wiring": {}
}
